{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:ectropy:schema:caas:takt-zone",
  "title": "Takt Zone",
  "description": "Spatial zone for takt planning and flow scheduling",
  "type": "object",
  "required": [
    "id",
    "name",
    "projectId",
    "geometry"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ZONE-[0-9]{4}-[0-9]{4,}$",
      "description": "Unique takt zone identifier"
    },
    "name": {
      "type": "string",
      "description": "Zone name (e.g., Floor 1 West, Building A Corridor)"
    },
    "projectId": {
      "type": "string",
      "description": "Parent project reference"
    },
    "geometry": {
      "$ref": "#/definitions/ZoneGeometry",
      "description": "3D spatial boundary of zone"
    },
    "workScope": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "trade": {
            "type": "string"
          },
          "workPackage": {
            "type": "string"
          },
          "estimatedDuration": {
            "type": "number",
            "description": "Days"
          },
          "crewSize": {
            "type": "number"
          },
          "predecessors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "description": "Work to be performed in this zone"
    },
    "taktTime": {
      "type": "number",
      "description": "Target takt time in days for this zone"
    },
    "bufferDays": {
      "type": "number",
      "description": "Schedule buffer for this zone"
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "READY",
        "IN_PROGRESS",
        "COMPLETE",
        "ON_HOLD"
      ],
      "description": "Current zone status"
    },
    "assignedWagon": {
      "type": "string",
      "description": "Wagon ID currently working in this zone"
    },
    "completionDate": {
      "type": "string",
      "format": "date-time",
      "description": "Actual completion timestamp"
    }
  },
  "definitions": {
    "ZoneGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Polygon",
            "MultiPolygon"
          ],
          "description": "GeoJSON geometry type"
        },
        "coordinates": {
          "type": "array",
          "description": "GeoJSON coordinates array"
        },
        "level": {
          "type": "string",
          "description": "Building level/floor"
        },
        "elevation": {
          "type": "number",
          "description": "Base elevation in project units"
        },
        "height": {
          "type": "number",
          "description": "Zone height in project units"
        },
        "area": {
          "type": "number",
          "description": "Floor area in sq ft/m"
        },
        "volume": {
          "type": "number",
          "description": "Volume in cu ft/m"
        }
      }
    }
  }
}
