{
  "name": "@ectropy/schemas",
  "version": "0.2.0",
  "description": "Ectropy schema definitions — voxel, decision, authority, federation. Consumed by @ectropy-ai/core and Ectropy-Business.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "main": "./types/index.ts",
  "types": "./types/index.ts",
  "exports": {
    ".": "./types/index.ts",
    "./types": "./types/index.ts",
    "./types/bundle": "./types/bundle.types.ts",
    "./types/decision-seed": "./types/decision-seed.types.ts",
    "./types/ifc-extraction": "./types/ifc-extraction.types.ts",
    "./types/voxel": "./types/voxel.types.ts",
    "./types/construction-element": "./types/construction-element.types.ts",
    "./types/speckle-stream": "./types/speckle-stream.types.ts",
    "./types/uploaded-ifc-file": "./types/uploaded-ifc-file.types.ts",
    "./schemas/*": "./*.schema.json",
    "./schema-index.json": "./schema-index.json"
  },
  "files": [
    "types/**/*.ts",
    "*.schema.json",
    "schema-index.json",
    "**/*.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ectropy-ai/schemas.git"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "ectropy",
    "schemas",
    "construction",
    "bim",
    "voxel",
    "decision",
    "federation"
  ]
}
