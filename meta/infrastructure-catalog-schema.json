{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:ectropy:schema:meta:infrastructure-catalog-schema",
  "title": "Infrastructure Catalog Schema",
  "description": "JSON schema for Ectropy infrastructure catalog - servers, services, ports, workflows, and secrets",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "metadata",
    "servers",
    "services",
    "ports",
    "workflows",
    "secrets",
    "indexes"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the catalog schema"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "metadata": {
      "type": "object",
      "required": [
        "catalogId",
        "purpose",
        "maintainer"
      ],
      "properties": {
        "catalogId": {
          "type": "string",
          "const": "infrastructure-catalog"
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of this catalog"
        },
        "maintainer": {
          "type": "string",
          "description": "Primary maintainer (human or ai-agents)"
        },
        "humanViewUrl": {
          "type": "string",
          "description": "Path to generated markdown view"
        }
      }
    },
    "servers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/server"
      },
      "description": "Physical and virtual servers in the infrastructure"
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/service"
      },
      "description": "Services and applications running in the infrastructure"
    },
    "ports": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/port"
      },
      "description": "Network ports used across the infrastructure"
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/workflow"
      },
      "description": "GitHub Actions workflows"
    },
    "secrets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/secret"
      },
      "description": "Secrets and credentials used in the infrastructure"
    },
    "indexes": {
      "$ref": "#/definitions/indexes",
      "description": "Indexes for efficient lookups"
    }
  },
  "definitions": {
    "server": {
      "type": "object",
      "required": [
        "serverId",
        "name",
        "ipAddress",
        "environment"
      ],
      "properties": {
        "serverId": {
          "type": "string",
          "pattern": "^server-[a-z0-9-]+$",
          "description": "Unique server identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable server name"
        },
        "ipAddress": {
          "type": "string",
          "description": "Server IP address"
        },
        "environment": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "development",
            "test"
          ],
          "description": "Environment classification"
        },
        "provider": {
          "type": "string",
          "description": "Cloud provider (e.g., DigitalOcean, AWS)"
        },
        "purpose": {
          "type": "string",
          "description": "Primary purpose of the server"
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Service IDs running on this server"
        },
        "runners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "GitHub Actions runner labels"
        },
        "specs": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            },
            "disk": {
              "type": "string"
            },
            "os": {
              "type": "string"
            }
          },
          "description": "Server specifications"
        },
        "sshAccess": {
          "type": "string",
          "description": "SSH access method or secret reference"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        }
      }
    },
    "service": {
      "type": "object",
      "required": [
        "serviceId",
        "name",
        "type",
        "ports"
      ],
      "properties": {
        "serviceId": {
          "type": "string",
          "pattern": "^service-[a-z0-9-]+$",
          "description": "Unique service identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable service name"
        },
        "type": {
          "type": "string",
          "enum": [
            "api",
            "web",
            "database",
            "cache",
            "mcp",
            "proxy",
            "runner",
            "monitoring"
          ],
          "description": "Service type"
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Port IDs used by this service"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Service IDs this service depends on"
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "timeout": {
              "type": "string"
            }
          },
          "description": "Health check configuration"
        },
        "containerName": {
          "type": "string",
          "description": "Docker container name"
        },
        "image": {
          "type": "string",
          "description": "Docker image reference"
        },
        "environment": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Environment variables or secret references"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        }
      }
    },
    "port": {
      "type": "object",
      "required": [
        "portId",
        "number",
        "protocol",
        "service"
      ],
      "properties": {
        "portId": {
          "type": "string",
          "pattern": "^port-[0-9]+(-[a-z0-9-]+)?$",
          "description": "Unique port identifier"
        },
        "number": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Port number"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "HTTP",
            "HTTPS",
            "TCP",
            "UDP"
          ],
          "description": "Network protocol"
        },
        "service": {
          "type": "string",
          "description": "Service ID using this port"
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of this port"
        },
        "exposed": {
          "type": "boolean",
          "description": "Whether port is exposed externally"
        },
        "nginxRoute": {
          "type": "string",
          "description": "Nginx reverse proxy route configuration"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": [
        "workflowId",
        "name",
        "path",
        "trigger"
      ],
      "properties": {
        "workflowId": {
          "type": "string",
          "pattern": "^workflow-[a-z0-9-]+$",
          "description": "Unique workflow identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable workflow name"
        },
        "path": {
          "type": "string",
          "description": "Workflow file path relative to .github/workflows"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "push",
            "pull_request",
            "schedule",
            "workflow_dispatch",
            "manual"
          ],
          "description": "Primary trigger type"
        },
        "schedule": {
          "type": "string",
          "description": "Cron schedule if trigger is 'schedule'"
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Service IDs used by this workflow"
        },
        "runners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Runner labels used by this workflow"
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Secret IDs used by this workflow"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Workflow IDs this workflow depends on"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        }
      }
    },
    "secret": {
      "type": "object",
      "required": [
        "secretId",
        "name",
        "scope"
      ],
      "properties": {
        "secretId": {
          "type": "string",
          "pattern": "^secret-[a-z0-9-]+$",
          "description": "Unique secret identifier"
        },
        "name": {
          "type": "string",
          "description": "Secret name as used in GitHub/environment"
        },
        "scope": {
          "type": "string",
          "enum": [
            "repository",
            "environment",
            "organization"
          ],
          "description": "Secret scope"
        },
        "usedBy": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Workflow IDs or service IDs using this secret"
        },
        "description": {
          "type": "string",
          "description": "Secret purpose and usage"
        },
        "rotation": {
          "type": "string",
          "description": "Rotation schedule or policy"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        }
      }
    },
    "indexes": {
      "type": "object",
      "properties": {
        "byEnvironment": {
          "type": "object",
          "patternProperties": {
            "^(production|staging|development|test)$": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Index of servers and services by environment"
        },
        "byServiceType": {
          "type": "object",
          "patternProperties": {
            "^[a-z-]+$": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Index of services by type"
        },
        "byPort": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+$": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Index of services by port number"
        },
        "byServer": {
          "type": "object",
          "patternProperties": {
            "^server-[a-z0-9-]+$": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Index of services by server"
        },
        "byWorkflowTrigger": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Index of workflows by trigger type"
        }
      },
      "description": "Indexes for O(1) lookups"
    }
  }
}
